<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RentalApp.Views.ProfilePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             xmlns:models="clr-namespace:RentalApp.Database.Models;assembly=RentalApp.Database"
             x:DataType="vm:ProfileViewModel"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <vm:ProfileViewModel/>
    </ContentPage.BindingContext>

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}">
        <ScrollView>
            <Grid Padding="20" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Error banner -->
                <Border Grid.Row="0"
                        BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                        Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                        StrokeThickness="1"
                        Padding="12"
                        IsVisible="{Binding HasError}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding ErrorMessage}"
                               TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                               VerticalOptions="Center"/>
                        <Button Grid.Column="1"
                                Text="×"
                                Command="{Binding ClearErrorCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                                FontSize="18"
                                Padding="4"
                                WidthRequest="32"
                                HeightRequest="32"/>
                    </Grid>
                </Border>

                <!-- Loading indicator -->
                <ActivityIndicator Grid.Row="1"
                                   IsRunning="{Binding IsRefreshing}"
                                   IsVisible="{Binding IsRefreshing}"
                                   HorizontalOptions="Center"
                                   Margin="0,40,0,0"/>

                <!-- Profile content — only shown once loaded -->
                <StackLayout Grid.Row="2"
                             Spacing="16"
                             IsVisible="{Binding IsLoaded}">

                    <!-- User info card -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            Padding="24">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <StackLayout HorizontalOptions="Center" Spacing="6">
                            <Label Text="👤"
                                   FontSize="40"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding CurrentUser.FullName}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding CurrentUser.Email}"
                                   FontSize="14"
                                   TextColor="White"
                                   Opacity="0.85"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding CurrentUser.CreatedAt, StringFormat='Member since {0:MMMM yyyy}'}"
                                   FontSize="13"
                                   TextColor="White"
                                   Opacity="0.75"
                                   HorizontalOptions="Center"/>
                        </StackLayout>
                    </Border>

                    <!-- Rating summary card -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                            StrokeThickness="1"
                            Padding="20">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="0">

                            <!-- Average rating stat -->
                            <StackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                                <Label Text="{Binding AverageRatingDisplay}"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                <Label Text="Average Rating"
                                       FontSize="12"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                            </StackLayout>

                            <!-- Divider -->
                            <BoxView Grid.Column="1"
                                     WidthRequest="1"
                                     BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                     VerticalOptions="Fill"
                                     Margin="0,4"/>

                            <!-- Review count stat -->
                            <StackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                                <Label Text="{Binding TotalReviews}"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                <Label Text="Reviews Written"
                                       FontSize="12"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                            </StackLayout>
                        </Grid>
                    </Border>

                    <!-- Reviews section header -->
                    <Label Text="Reviews Written"
                           FontSize="18"
                           FontAttributes="Bold"
                           Margin="0,8,0,0"/>

                    <!-- Empty state -->
                    <Label Text="You haven't written any reviews yet."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                           IsVisible="{Binding IsEmpty}"
                           Margin="0,4,0,16"/>

                    <!-- Review list -->
                    <CollectionView ItemsSource="{Binding Reviews}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Review">
                                <Border Margin="0,4"
                                        Padding="14"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                        StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto"
                                          RowDefinitions="Auto,Auto,Auto"
                                          RowSpacing="4">
                                        <!-- Item title + star rating -->
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding ItemTitle}"
                                               FontAttributes="Bold"
                                               FontSize="14"/>
                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Rating, StringFormat='{0} ★'}"
                                               FontAttributes="Bold"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                        <!-- Optional comment -->
                                        <Label Grid.Row="1" Grid.ColumnSpan="2"
                                               Text="{Binding Comment}"
                                               FontSize="13"
                                               LineBreakMode="WordWrap"
                                               IsVisible="{Binding Comment, Converter={StaticResource StringToBoolConverter}}"/>
                                        <!-- Date -->
                                        <Label Grid.Row="2" Grid.ColumnSpan="2"
                                               Text="{Binding CreatedAt, StringFormat='{0:d MMM yyyy}'}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Logout button -->
                    <Button Text="Log out"
                            Command="{Binding LogoutCommand}"
                            Margin="0,16,0,8"
                            BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#3B0000}"
                            TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"/>

                </StackLayout>
            </Grid>
        </ScrollView>
    </RefreshView>
</ContentPage>
