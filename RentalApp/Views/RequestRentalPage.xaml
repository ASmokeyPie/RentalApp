<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RentalApp.Views.RequestRentalPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             x:DataType="vm:RequestRentalViewModel"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <vm:RequestRentalViewModel/>
    </ContentPage.BindingContext>

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding LoadCommand}">
        <ScrollView>
            <StackLayout Padding="20" Spacing="16">

                <!-- Error banner -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                        Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                        StrokeThickness="1"
                        Padding="12"
                        IsVisible="{Binding HasError}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding ErrorMessage}"
                               TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                               VerticalOptions="Center"/>
                        <Button Grid.Column="1"
                                Text="×"
                                Command="{Binding ClearErrorCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                                FontSize="18"
                                Padding="4"
                                WidthRequest="32"
                                HeightRequest="32"/>
                    </Grid>
                </Border>

                <!-- Item summary (read-only) -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        StrokeThickness="1"
                        Padding="14"
                        IsVisible="{Binding IsLoaded}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <StackLayout Spacing="4">
                        <Label Text="{Binding Item.Title}"
                               FontSize="18"
                               FontAttributes="Bold"/>
                        <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} per day'}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        <Label Text="{Binding Item.OwnerName, StringFormat='Owner: {0}'}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                    </StackLayout>
                </Border>

                <!-- Date selection -->
                <StackLayout Spacing="14" IsVisible="{Binding IsLoaded}">
                    <Label Text="Start date" FontAttributes="Bold"/>
                    <DatePicker Date="{Binding StartDate}"
                                MinimumDate="{Binding MinimumStartDate}"
                                Format="ddd, d MMM yyyy"/>

                    <Label Text="End date" FontAttributes="Bold"/>
                    <DatePicker Date="{Binding EndDate}"
                                MinimumDate="{Binding MinimumEndDate}"
                                Format="ddd, d MMM yyyy"/>

                    <!-- Live price summary -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                            StrokeThickness="1"
                            Padding="14"
                            Margin="0,8,0,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding TotalDays, StringFormat='{0} days'}"
                                   FontSize="14"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Item.DailyRate, StringFormat='@ £{0:F2}/day'}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Total"
                                   FontSize="16"
                                   FontAttributes="Bold"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding TotalPrice, StringFormat='£{0:F2}'}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Grid>
                    </Border>

                    <Button Text="Submit rental request"
                            Command="{Binding SubmitCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            Margin="0,12,0,0"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center"/>
                </StackLayout>
            </StackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
