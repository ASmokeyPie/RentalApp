<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RentalApp.Views.ItemsListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             xmlns:models="clr-namespace:RentalApp.Database.Models;assembly=RentalApp.Database"
             x:DataType="vm:ItemsListViewModel"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <vm:ItemsListViewModel/>
    </ContentPage.BindingContext>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ New"
                     Command="{Binding NavigateToCreateItemCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Error banner -->
        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                StrokeThickness="1"
                Padding="12"
                Margin="12,12,12,0"
                IsVisible="{Binding HasError}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                       VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        Text="×"
                        Command="{Binding ClearErrorCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                        FontSize="18"
                        Padding="4"
                        WidthRequest="32"
                        HeightRequest="32"/>
            </Grid>
        </Border>

        <!-- Category filter row -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8"
              Padding="12,10,12,4">

            <Border Grid.Column="0"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Picker ItemsSource="{Binding CategoryFilters}"
                        SelectedItem="{Binding SelectedCategoryFilter}"
                        ItemDisplayBinding="{Binding Name}"
                        Title="All Categories"
                        IsEnabled="{Binding IsLoadingCategories, Converter={StaticResource InvertedBoolConverter}}"
                        Margin="8,0"/>
            </Border>

            <ActivityIndicator Grid.Column="1"
                               IsRunning="{Binding IsLoadingCategories}"
                               IsVisible="{Binding IsLoadingCategories}"
                               WidthRequest="24"
                               HeightRequest="24"
                               VerticalOptions="Center"/>
        </Grid>

        <!-- Items list with pull-to-refresh. Paging is driven by the
             explicit Load-more button below, not infinite scroll. -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView x:Name="ItemsCollection"
                            ItemsSource="{Binding Items}"
                            SelectionMode="None">

                <CollectionView.EmptyView>
                    <Grid Padding="40" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0"
                               Text="No items to show"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               IsVisible="{Binding IsEmpty}"/>
                        <Label Grid.Row="1"
                               Text="Try a different category, or pull down to refresh."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                               HorizontalTextAlignment="Center"
                               HorizontalOptions="Center"
                               IsVisible="{Binding IsEmpty}"/>
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Item">
                        <!-- Card with coloured left accent bar -->
                        <Border Margin="12,5"
                                Padding="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference ItemsCollection}, Path=BindingContext.SelectItemCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="5,*" ColumnSpacing="0">

                                <!-- Left accent bar -->
                                <BoxView Grid.Column="0"
                                         BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                         VerticalOptions="Fill"/>

                                <!-- Content area -->
                                <Grid Grid.Column="1"
                                      Padding="14,12"
                                      ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto"
                                      RowSpacing="4">

                                    <!-- Title -->
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Title}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation"/>

                                    <!-- Price -->
                                    <Label Grid.Row="0" Grid.Column="1"
                                           Text="{Binding DailyRate, StringFormat='£{0:F2}/day'}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

                                    <!-- Category pill -->
                                    <Border Grid.Row="1" Grid.Column="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=#2D1B6E}"
                                            Stroke="Transparent"
                                            Padding="6,2"
                                            HorizontalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding CategoryName}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource PrimaryDark}}"/>
                                    </Border>

                                    <!-- Owner -->
                                    <Label Grid.Row="2" Grid.ColumnSpan="2"
                                           Text="{Binding OwnerName, StringFormat='Owner: {0}'}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Footer: Load-more button + item count + loading spinner -->
        <StackLayout Grid.Row="3"
                Padding="12,8"
                Spacing="6">
            <Button Text="{Binding RemainingCount, StringFormat='Load more ({0} remaining)'}"
                    Command="{Binding LoadMoreCommand}"
                    IsVisible="{Binding HasMorePages}"
                    IsEnabled="{Binding IsLoadingMore, Converter={StaticResource InvertedBoolConverter}}"/>

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding TotalCount, StringFormat='{0} items total'}"
                       VerticalOptions="Center"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsLoadingMore}"
                                   IsVisible="{Binding IsLoadingMore}"
                                   WidthRequest="20"
                                   HeightRequest="20"/>
            </Grid>
        </StackLayout>
    </Grid>
</ContentPage>
