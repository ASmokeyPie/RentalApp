<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RentalApp.Views.ItemsListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             xmlns:models="clr-namespace:RentalApp.Database.Models;assembly=RentalApp.Database"
             x:DataType="vm:ItemsListViewModel"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <vm:ItemsListViewModel/>
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Error banner -->
        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                StrokeThickness="1"
                Padding="12"
                Margin="12,12,12,0"
                IsVisible="{Binding HasError}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                       VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        Text="×"
                        Command="{Binding ClearErrorCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                        FontSize="18"
                        Padding="4"
                        WidthRequest="32"
                        HeightRequest="32"/>
            </Grid>
        </Border>

        <!-- Items list with pull-to-refresh and infinite scroll -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}">
            <CollectionView x:Name="ItemsCollection"
                            ItemsSource="{Binding Items}"
                            SelectionMode="None"
                            RemainingItemsThreshold="3"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">

                <CollectionView.EmptyView>
                    <Grid Padding="40" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0"
                               Text="No items to show"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               IsVisible="{Binding IsEmpty}"/>
                        <Label Grid.Row="1"
                               Text="Pull down to refresh."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                               HorizontalOptions="Center"
                               IsVisible="{Binding IsEmpty}"/>
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Item">
                        <Border Margin="12,6"
                                Padding="12"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference ItemsCollection}, Path=BindingContext.SelectItemCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"/>

                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding DailyRate, StringFormat='£{0:F2}/day'}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

                                <Label Grid.Row="1" Grid.ColumnSpan="2"
                                       Text="{Binding CategoryName}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>

                                <Label Grid.Row="2" Grid.ColumnSpan="2"
                                       Text="{Binding OwnerName, StringFormat='Owner: {0}'}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Footer: load-more spinner + total -->
        <Grid Grid.Row="2" Padding="12" ColumnDefinitions="*,Auto">
            <Label Grid.Column="0"
                   Text="{Binding TotalCount, StringFormat='{0} items'}"
                   VerticalOptions="Center"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
            <ActivityIndicator Grid.Column="1"
                               IsRunning="{Binding IsLoadingMore}"
                               IsVisible="{Binding IsLoadingMore}"
                               WidthRequest="20"
                               HeightRequest="20"/>
        </Grid>
    </Grid>
</ContentPage>
