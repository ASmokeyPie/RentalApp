<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RentalApp.Views.RegisterPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <vm:RegisterViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <Grid Padding="28,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackLayout Grid.Row="0"
                         HorizontalOptions="Center"
                         Spacing="4"
                         Margin="0,36,0,28">
                <Label Text="Create Account"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                <Label Text="Join RentalApp and start renting"
                       FontSize="13"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
            </StackLayout>

            <!-- Error Message -->
            <Border Grid.Row="1"
                    BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                    Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                    StrokeThickness="1"
                    Padding="14"
                    Margin="0,0,0,8"
                    IsVisible="{Binding HasError}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                       FontSize="14"/>
            </Border>

            <!-- First Name Entry -->
            <Border Grid.Row="2"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1.5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Margin="0,0,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry Text="{Binding FirstName}"
                       Placeholder="First name"
                       ReturnType="Next"
                       Margin="14,8"/>
            </Border>

            <!-- Last Name Entry -->
            <Border Grid.Row="3"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1.5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Margin="0,0,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry Text="{Binding LastName}"
                       Placeholder="Last name"
                       ReturnType="Next"
                       Margin="14,8"/>
            </Border>

            <!-- Email Entry -->
            <Border Grid.Row="4"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1.5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Margin="0,0,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry Text="{Binding Email}"
                       Placeholder="Email address"
                       Keyboard="Email"
                       ReturnType="Next"
                       Margin="14,8"/>
            </Border>

            <!-- Password Entry -->
            <Border Grid.Row="5"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1.5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Margin="0,0,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry Text="{Binding Password}"
                       Placeholder="Password"
                       IsPassword="True"
                       ReturnType="Next"
                       Margin="14,8"/>
            </Border>

            <!-- Confirm Password Entry -->
            <Border Grid.Row="6"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1.5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Margin="0,0,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry Text="{Binding ConfirmPassword}"
                       Placeholder="Confirm password"
                       IsPassword="True"
                       ReturnType="Done"
                       Margin="14,8"/>
            </Border>

            <!-- Terms and Conditions -->
            <StackLayout Grid.Row="7"
                         Orientation="Horizontal"
                         HorizontalOptions="Start"
                         Margin="0,0,0,20">
                <CheckBox IsChecked="{Binding AcceptTerms}"/>
                <Label Text="I accept the terms and conditions"
                       VerticalOptions="Center"
                       FontSize="14"/>
            </StackLayout>

            <!-- Register Button -->
            <Button Grid.Row="8"
                    Text="Create Account"
                    Command="{Binding RegisterCommand}"
                    HeightRequest="52"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="0,0,0,8"/>

            <!-- Footer: loading + back to login -->
            <StackLayout Grid.Row="9" Spacing="8" Margin="0,8,0,40">
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"/>
                <Button Text="Already have an account? Sign in"
                        Command="{Binding NavigateBackToLoginCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        FontSize="14"/>
            </StackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
