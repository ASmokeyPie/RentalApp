<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RentalApp.Views.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <vm:MainViewModel/>
    </ContentPage.BindingContext>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Nearby"
                     Command="{Binding NavigateToFindNearbyCommand}"/>
        <ToolbarItem Text="+"
                     Command="{Binding NavigateToCreateItemCommand}"/>
        <ToolbarItem Text="Rentals"
                     Command="{Binding NavigateToMyRentalsCommand}"/>
        <ToolbarItem Text="Profile"
                     Command="{Binding NavigateToProfileCommand}"
                     IconImageSource="user.png"/>
        <ToolbarItem Text="Settings"
                     Command="{Binding NavigateToSettingsCommand}"
                     IconImageSource="settings.png"/>
        <ToolbarItem Text="Logout"
                     Command="{Binding LogoutCommand}"
                     IconImageSource="logout.png"/>
    </ContentPage.ToolbarItems>

    <RefreshView IsRefreshing="{Binding IsBusy}"
                 Command="{Binding RefreshDataCommand}">
        <ScrollView>
            <StackLayout Padding="16,20" Spacing="16">

                <!-- Welcome banner -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Padding="20,18"
                        Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light={StaticResource Primary}, Dark=Transparent}"
                                Offset="0,4"
                                Radius="12"
                                Opacity="0.25"/>
                    </Border.Shadow>
                    <StackLayout Spacing="4" VerticalOptions="Center">
                        <Label Text="{Binding WelcomeMessage}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding CurrentUser.Email}"
                               FontSize="13"
                               TextColor="White"
                               Opacity="0.8"
                               HorizontalOptions="Center"/>
                    </StackLayout>
                </Border>

                <!-- Error Display -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                        Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                        StrokeThickness="1"
                        Padding="15"
                        IsVisible="{Binding HasError}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <StackLayout Orientation="Horizontal">
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                               FontSize="14"
                               VerticalOptions="Center"
                               HorizontalOptions="StartAndExpand"/>
                        <Button Text="×"
                                Command="{Binding ClearErrorCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                                FontSize="18"
                                Padding="5"
                                WidthRequest="30"
                                HeightRequest="30"/>
                    </StackLayout>
                </Border>

                <!-- Quick Actions heading -->
                <Label Text="Quick Actions"
                       Style="{StaticResource SectionHeader}"/>

                <!-- Browse Items card -->
                <Border Style="{StaticResource CardBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToItemsListCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=#2D1B6E}"
                                WidthRequest="44" HeightRequest="44"
                                Stroke="Transparent"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="📦" FontSize="22"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Browse Items" FontSize="15" FontAttributes="Bold"/>
                            <Label Text="View available items for rent"
                                   Style="{StaticResource CaptionLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                    </Grid>
                </Border>

                <!-- My Rentals card -->
                <Border Style="{StaticResource CardBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToMyRentalsCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=#2D1B6E}"
                                WidthRequest="44" HeightRequest="44"
                                Stroke="Transparent"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="🤝" FontSize="22"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="My Rentals" FontSize="15" FontAttributes="Bold"/>
                            <Label Text="Track incoming and outgoing rentals"
                                   Style="{StaticResource CaptionLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                    </Grid>
                </Border>

                <!-- Find Nearby card -->
                <Border Style="{StaticResource CardBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToFindNearbyCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=#2D1B6E}"
                                WidthRequest="44" HeightRequest="44"
                                Stroke="Transparent"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="📍" FontSize="22"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Find Nearby" FontSize="15" FontAttributes="Bold"/>
                            <Label Text="Discover items close to you"
                                   Style="{StaticResource CaptionLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                    </Grid>
                </Border>

                <!-- Profile card -->
                <Border Style="{StaticResource CardBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToProfileCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=#2D1B6E}"
                                WidthRequest="44" HeightRequest="44"
                                Stroke="Transparent"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="👤" FontSize="22"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Profile" FontSize="15" FontAttributes="Bold"/>
                            <Label Text="Manage your account"
                                   Style="{StaticResource CaptionLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                    </Grid>
                </Border>

            </StackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
